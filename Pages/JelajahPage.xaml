<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="VolcanoMonitor.Pages.JelajahPage"
             BackgroundColor="#000000">

    <Grid>
        <!-- MAIN PAGE CONTENT -->
        <ScrollView x:Name="MainScroll">
            <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="12" Padding="20">

                <!-- SECTION 0: HEADER -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,5">
                    <VerticalStackLayout Grid.Column="0">
                        <Label Text="JELAJAH · ANALITIS" FontSize="9" CharacterSpacing="2" FontAttributes="Bold" TextColor="#E10600"/>
                        <Label Text="INFORMASI VULKANIK" FontSize="20" FontAttributes="Bold" TextColor="White" Margin="0,-2,0,0"/>
                    </VerticalStackLayout>
                </Grid>

                <!-- SECTION 1: SEARCH & VOLCANO SELECTOR -->
                <VerticalStackLayout Grid.Row="1" Spacing="8">
                    <!-- Custom Swiss search layout -->
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Entry x:Name="TxtSearch" Placeholder="CARI GUNUNG BERAPI..." PlaceholderColor="#666" TextColor="White" BackgroundColor="#0D0D0D" HeightRequest="40" Grid.Column="0" TextChanged="OnSearchTextChanged"/>
                        <Button Text="CARI" Clicked="OnSearchClicked" BackgroundColor="#E10600" TextColor="White" HeightRequest="40" CornerRadius="0" Padding="12,0" FontAttributes="Bold" FontSize="11" Grid.Column="1"/>
                    </Grid>

                    <!-- Horizontal selection tabs for Volcanoes -->
                    <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never" HeightRequest="38">
                        <HorizontalStackLayout x:Name="VolcanoSelectorContainer" Spacing="8" VerticalOptions="Center">
                            <!-- Populated in codebehind -->
                        </HorizontalStackLayout>
                    </ScrollView>
                </VerticalStackLayout>

                <!-- SECTION 2: VOLCANO DETAIL SUMMARY -->
                <Border x:Name="DetailsBorder" Grid.Row="2" BackgroundColor="#0D0D0D" StrokeThickness="1" Stroke="#222" Padding="16">
                    <VerticalStackLayout Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label x:Name="LblVolcanoName" Text="GUNUNG MERAPI" FontSize="22" FontAttributes="Bold" TextColor="White"/>
                            <Label x:Name="LblVolcanoStatus" Grid.Column="1" Text="SIAGA" FontSize="10" FontAttributes="Bold" TextColor="White" BackgroundColor="#FF8C00" Padding="8,4"/>
                        </Grid>

                        <Label x:Name="LblVolcanoMeta" Text="Lokasi: Sleman, Yogyakarta • Elevasi: 2910m" TextColor="Gray" FontSize="12" FontAttributes="Bold"/>

                        <Label x:Name="LblVolcanoDesc" Text="Gunung berapi tipe kerucut teraktif di Indonesia..." TextColor="#AAA" FontSize="13" LineBreakMode="WordWrap"/>

                        <Border BackgroundColor="#150505" StrokeThickness="1" Stroke="#551111" Padding="10" Margin="0,4,0,0">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="🔴 ZONA BAHAYA EVAKUASI" TextColor="#E10600" FontSize="10" FontAttributes="Bold" CharacterSpacing="1"/>
                                <Label x:Name="LblHazardZone" Text="Radius bahaya 5 km dari puncak kawah. Dilarang melakukan aktivitas pendakian maupun penambangan pasir." TextColor="White" FontSize="12"/>
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <!-- SECTION 3: SENSOR TELEMETRY, AI & CHARTS -->
                <Grid Grid.Row="3" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="12">

                    <!-- 3.1. Telemetry solid boxes -->
                    <Grid Grid.Row="0" ColumnDefinitions="*,*,*,*,*" ColumnSpacing="6">
                        <Border Grid.Column="0" BackgroundColor="#0D0D0D" StrokeThickness="1" Stroke="#222" Padding="6">
                            <VerticalStackLayout HorizontalOptions="Center">
                                <Label Text="SO₂" FontSize="9" TextColor="Gray" HorizontalTextAlignment="Center"/>
                                <Label x:Name="LblValSO2" Text="--" FontSize="13" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center"/>
                                <Label Text="ppm" FontSize="8" TextColor="#444" HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="1" BackgroundColor="#0D0D0D" StrokeThickness="1" Stroke="#222" Padding="6">
                            <VerticalStackLayout HorizontalOptions="Center">
                                <Label Text="CO₂" FontSize="9" TextColor="Gray" HorizontalTextAlignment="Center"/>
                                <Label x:Name="LblValCO2" Text="--" FontSize="13" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center"/>
                                <Label Text="ppm" FontSize="8" TextColor="#444" HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="2" BackgroundColor="#0D0D0D" StrokeThickness="1" Stroke="#222" Padding="6">
                            <VerticalStackLayout HorizontalOptions="Center">
                                <Label Text="H₂S" FontSize="9" TextColor="Gray" HorizontalTextAlignment="Center"/>
                                <Label x:Name="LblValH2S" Text="--" FontSize="13" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center"/>
                                <Label Text="ppm" FontSize="8" TextColor="#444" HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="3" BackgroundColor="#0D0D0D" StrokeThickness="1" Stroke="#222" Padding="6">
                            <VerticalStackLayout HorizontalOptions="Center">
                                <Label Text="SUHU" FontSize="9" TextColor="Gray" HorizontalTextAlignment="Center"/>
                                <Label x:Name="LblValTemp" Text="--" FontSize="13" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center"/>
                                <Label Text="°C" FontSize="8" TextColor="#444" HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="4" BackgroundColor="#0D0D0D" StrokeThickness="1" Stroke="#222" Padding="6">
                            <VerticalStackLayout HorizontalOptions="Center">
                                <Label Text="SEIS" FontSize="9" TextColor="Gray" HorizontalTextAlignment="Center"/>
                                <Label x:Name="LblValSeis" Text="--" FontSize="13" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center"/>
                                <Label Text="idx" FontSize="8" TextColor="#444" HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- 3.2. Skia Graph Card -->
                    <Border Grid.Row="1" BackgroundColor="#0D0D0D" StrokeThickness="1" Stroke="#222" Padding="14">
                        <VerticalStackLayout Spacing="8">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label x:Name="LblChartTitle" Text="GRAFIK TREN SO₂ (10 JAM TERAKHIR)" TextColor="#888" FontSize="10" CharacterSpacing="1" FontAttributes="Bold"/>
                            </Grid>

                            <!-- Graph toggle parameters -->
                            <HorizontalStackLayout Spacing="6">
                                <Button x:Name="BtnParamSO2" Text="SO₂" Clicked="OnParamToggleClicked" CommandParameter="SO2" BackgroundColor="White" TextColor="Black" FontSize="9" FontAttributes="Bold" CornerRadius="0" Padding="8,4" HeightRequest="22"/>
                                <Button x:Name="BtnParamCO2" Text="CO₂" Clicked="OnParamToggleClicked" CommandParameter="CO2" BackgroundColor="#111" TextColor="White" FontSize="9" FontAttributes="Bold" CornerRadius="0" Padding="8,4" HeightRequest="22"/>
                                <Button x:Name="BtnParamH2S" Text="H₂S" Clicked="OnParamToggleClicked" CommandParameter="H2S" BackgroundColor="#111" TextColor="White" FontSize="9" FontAttributes="Bold" CornerRadius="0" Padding="8,4" HeightRequest="22"/>
                                <Button x:Name="BtnParamTemp" Text="TEMP" Clicked="OnParamToggleClicked" CommandParameter="TEMPERATURE" BackgroundColor="#111" TextColor="White" FontSize="9" FontAttributes="Bold" CornerRadius="0" Padding="8,4" HeightRequest="22"/>
                                <Button x:Name="BtnParamSeis" Text="SEIS" Clicked="OnParamToggleClicked" CommandParameter="SEISMIC" BackgroundColor="#111" TextColor="White" FontSize="9" FontAttributes="Bold" CornerRadius="0" Padding="8,4" HeightRequest="22"/>
                            </HorizontalStackLayout>

                            <!-- Skia Canvas -->
                            <skia:SKCanvasView x:Name="TelemetryChart" HeightRequest="130" PaintSurface="OnPaintTelemetryChart" Margin="0,6,0,0"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- 3.3. AI Neural Network & Fuzzy logic evaluation card -->
                    <Border Grid.Row="2" BackgroundColor="#0D0D0D" StrokeThickness="1" Stroke="#E10600" Padding="16">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="ANALISIS MODEL KECERDASAN BUATAN (AI)" TextColor="#E10600" FontSize="11" FontAttributes="Bold" CharacterSpacing="1"/>

                            <Grid ColumnDefinitions="*,*">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="NEURAL NETWORK CLASSIFIER" TextColor="Gray" FontSize="9" FontAttributes="Bold"/>
                                    <Label x:Name="LblNNResult" Text="AWAS (98.4%)" TextColor="White" FontSize="16" FontAttributes="Bold"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                    <Label Text="FUZZY RISK INDEX (MAMDANI)" TextColor="Gray" FontSize="9" FontAttributes="Bold"/>
                                    <Label x:Name="LblFuzzyResult" Text="Risk: 87.2%" TextColor="White" FontSize="16" FontAttributes="Bold"/>
                                </VerticalStackLayout>
                            </Grid>

                            <BoxView HeightRequest="1" Color="#222"/>

                            <!-- Layman terms result -->
                            <VerticalStackLayout Spacing="4">
                                <Label Text="PENJELASAN AWAM (INFORMASI WARGA)" TextColor="Gray" FontSize="9" FontAttributes="Bold"/>
                                <Label x:Name="LblLaymanExplanation" Text="Membaca data sensor..." TextColor="#DDD" FontSize="12" LineBreakMode="WordWrap"/>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- 3.4. Chatbot trigger button -->
                    <Button Grid.Row="3" Text="TANYA VULKANOBOT (AI CHATBOT) >" Clicked="OnOpenChatClicked" BackgroundColor="#E10600" TextColor="White" FontAttributes="Bold" CornerRadius="0" HeightRequest="46"/>

                </Grid>

            </Grid>
        </ScrollView>

        <!-- CHATBOT DRAWER OVERLAY (Slides up/Visible when triggered) -->
        <Grid x:Name="ChatOverlay" BackgroundColor="#F0000000" IsVisible="False" RowDefinitions="Auto,*,Auto" Padding="20">
            <!-- Header chat -->
            <Border Grid.Row="0" BackgroundColor="#0D0D0D" StrokeThickness="1" Stroke="#222" Padding="16">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout>
                        <Label Text="VULKANOBOT CHAT (GEMINI AI)" TextColor="#E10600" FontSize="11" FontAttributes="Bold" CharacterSpacing="1"/>
                        <Label x:Name="LblChatTarget" Text="Kontekstual: Gunung Merapi" TextColor="White" FontSize="14" FontAttributes="Bold"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="1" Text="TUTUP" Clicked="OnCloseChatClicked" BackgroundColor="Transparent" TextColor="Gray" FontAttributes="Bold" FontSize="12" Padding="0" VerticalOptions="Center"/>
                </Grid>
            </Border>

            <!-- Chat message list -->
            <ScrollView Grid.Row="1" x:Name="ChatScroll" Margin="0,10">
                <VerticalStackLayout x:Name="ChatHistoryContainer" Spacing="8">
                    <!-- Dynamically added chat bubbles -->
                </VerticalStackLayout>
            </ScrollView>

            <!-- Chat input bar -->
            <Border Grid.Row="2" BackgroundColor="#0D0D0D" StrokeThickness="1" Stroke="#222" Padding="10">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <Entry x:Name="TxtChatQuestion" Placeholder="TANYA SEPUTAR STATUS, DATA, MITIGASI..." PlaceholderColor="#555" TextColor="White" BackgroundColor="#050505" HeightRequest="42" ReturnCommand="{Binding SendChatQuestionCommand}"/>
                    <Button x:Name="SendButton" Grid.Column="1" Text="KIRIM" Clicked="OnSendChatClicked" BackgroundColor="#E10600" TextColor="White" FontAttributes="Bold" CornerRadius="0" Padding="12,0" HeightRequest="42"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentPage>