<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VolcanoMonitor.Pages.PengaturanPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#1B0B3B">

    <Grid>
        <!-- BG Gradient -->
        <Border StrokeThickness="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1B0B3B" Offset="0"/>
                    <GradientStop Color="#2D0F6F" Offset="0.6"/>
                    <GradientStop Color="#3A0CA3" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <ScrollView>
            <VerticalStackLayout Spacing="16" Padding="24,20">

                <!-- ===== HEADER ===== -->
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="PENGATURAN · SISTEM" FontSize="10" CharacterSpacing="2"
                               FontAttributes="Bold" TextColor="#FF2E9F"/>
                        <Label Text="PROFIL &amp; KONSOL" FontSize="22" FontAttributes="Bold"
                               TextColor="White"/>
                        <Label Text="Kelola akun, data gunung, dan parameter AI"
                               FontSize="12" TextColor="#B9A7D9"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="1" Text="LOGOUT" Clicked="OnLogoutClicked"
                            BackgroundColor="Transparent" TextColor="#FF2E9F"
                            BorderColor="#FF2E9F" BorderWidth="1" Padding="16,0"
                            HeightRequest="36" FontAttributes="Bold" FontSize="11"
                            CornerRadius="18" VerticalOptions="Center"/>
                </Grid>

                <!-- ===== SECTION 1: PROFIL EDIT ===== -->
                <Border Style="{StaticResource GlassCard}">
                    <VerticalStackLayout Spacing="12">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="👤" FontSize="18"/>
                            <Label Text="EDIT PROFIL AKUN" Style="{StaticResource LblSection}"
                                   TextColor="#FF2E9F" VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0" Spacing="5">
                                <Label Text="NAMA LENGKAP" Style="{StaticResource LblSection}"/>
                                <Border StrokeShape="RoundRectangle 12" BackgroundColor="#18FFFFFF"
                                        Stroke="#26FFFFFF" StrokeThickness="1" Padding="14,10">
                                    <Entry x:Name="TxtProfileName" TextColor="White"
                                           PlaceholderColor="#7B6FAA" BackgroundColor="Transparent"/>
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="5">
                                <Label Text="ALAMAT EMAIL" Style="{StaticResource LblSection}"/>
                                <Border StrokeShape="RoundRectangle 12" BackgroundColor="#18FFFFFF"
                                        Stroke="#26FFFFFF" StrokeThickness="1" Padding="14,10">
                                    <Entry x:Name="TxtProfileEmail" TextColor="White"
                                           PlaceholderColor="#7B6FAA" BackgroundColor="Transparent"
                                           Keyboard="Email"/>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="GANTI PASSWORD (KOSONGKAN JIKA TIDAK DIUBAH)" Style="{StaticResource LblSection}"/>
                            <Border StrokeShape="RoundRectangle 12" BackgroundColor="#18FFFFFF"
                                    Stroke="#26FFFFFF" StrokeThickness="1" Padding="14,10">
                                <Entry x:Name="TxtProfilePassword" IsPassword="True"
                                       Placeholder="Masukkan kata sandi baru..."
                                       PlaceholderColor="#7B6FAA" TextColor="White"
                                       BackgroundColor="Transparent"/>
                            </Border>
                        </VerticalStackLayout>

                        <Button Text="SIMPAN PERUBAHAN PROFIL" Clicked="OnSaveProfileClicked"
                                Style="{StaticResource BtnMagenta}" HeightRequest="44"/>
                    </VerticalStackLayout>
                </Border>

                <!-- ===== ADMIN CONSOLE HEADER ===== -->
                <Label x:Name="LblAdminConsoleHeader" Text="KONSOL UTAMA ADMINISTRATOR"
                       TextColor="#FF2E9F" FontSize="12" FontAttributes="Bold"
                       CharacterSpacing="1" IsVisible="False" Margin="4,8,0,0"/>

                <!-- ===== ADMIN PANEL ===== -->
                <VerticalStackLayout x:Name="AdminPanel" Spacing="16" IsVisible="False">

                    <!-- 2.1. Volcano Management (CRUD) -->
                    <Border Style="{StaticResource GlassCard}">
                        <VerticalStackLayout Spacing="10">
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="🌋" FontSize="16"/>
                                <Label Text="KELOLA DATA GUNUNG BERAPI (CRUD)" Style="{StaticResource LblSection}"
                                       TextColor="#4CC9F0" VerticalOptions="Center"/>
                            </HorizontalStackLayout>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10" RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                                <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="4">
                                    <Label Text="NAMA GUNUNG" Style="{StaticResource LblSection}"/>
                                    <Border StrokeShape="RoundRectangle 10" BackgroundColor="#18FFFFFF"
                                            Stroke="#26FFFFFF" StrokeThickness="1" Padding="12,8">
                                        <Entry x:Name="TxtVolcName" TextColor="White" BackgroundColor="Transparent"/>
                                    </Border>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="4">
                                    <Label Text="LOKASI / PROVINSI" Style="{StaticResource LblSection}"/>
                                    <Border StrokeShape="RoundRectangle 10" BackgroundColor="#18FFFFFF"
                                            Stroke="#26FFFFFF" StrokeThickness="1" Padding="12,8">
                                        <Entry x:Name="TxtVolcLocation" TextColor="White" BackgroundColor="Transparent"/>
                                    </Border>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="4">
                                    <Label Text="LATITUDE" Style="{StaticResource LblSection}"/>
                                    <Border StrokeShape="RoundRectangle 10" BackgroundColor="#18FFFFFF"
                                            Stroke="#26FFFFFF" StrokeThickness="1" Padding="12,8">
                                        <Entry x:Name="TxtVolcLat" TextColor="White" BackgroundColor="Transparent" Keyboard="Numeric"/>
                                    </Border>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="4">
                                    <Label Text="LONGITUDE" Style="{StaticResource LblSection}"/>
                                    <Border StrokeShape="RoundRectangle 10" BackgroundColor="#18FFFFFF"
                                            Stroke="#26FFFFFF" StrokeThickness="1" Padding="12,8">
                                        <Entry x:Name="TxtVolcLong" TextColor="White" BackgroundColor="Transparent" Keyboard="Numeric"/>
                                    </Border>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Row="2" Grid.Column="0" Spacing="4">
                                    <Label Text="ELEVASI (METER)" Style="{StaticResource LblSection}"/>
                                    <Border StrokeShape="RoundRectangle 10" BackgroundColor="#18FFFFFF"
                                            Stroke="#26FFFFFF" StrokeThickness="1" Padding="12,8">
                                        <Entry x:Name="TxtVolcElevation" TextColor="White" BackgroundColor="Transparent" Keyboard="Numeric"/>
                                    </Border>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Row="2" Grid.Column="1" Spacing="4">
                                    <Label Text="STATUS AWAL" Style="{StaticResource LblSection}"/>
                                    <Border StrokeShape="RoundRectangle 10" BackgroundColor="#18FFFFFF"
                                            Stroke="#26FFFFFF" StrokeThickness="1" Padding="4,0">
                                        <Picker x:Name="PickerVolcStatus" Title="STATUS..." TextColor="White"
                                                TitleColor="#7B6FAA" BackgroundColor="Transparent">
                                            <Picker.ItemsSource>
                                                <x:Array Type="{x:Type x:String}">
                                                    <x:String>NORMAL</x:String>
                                                    <x:String>WASPADA</x:String>
                                                    <x:String>SIAGA</x:String>
                                                    <x:String>AWAS</x:String>
                                                </x:Array>
                                            </Picker.ItemsSource>
                                        </Picker>
                                    </Border>
                                </VerticalStackLayout>
                            </Grid>

                            <VerticalStackLayout Spacing="4">
                                <Label Text="DESKRIPSI GUNUNG" Style="{StaticResource LblSection}"/>
                                <Border StrokeShape="RoundRectangle 10" BackgroundColor="#18FFFFFF"
                                        Stroke="#26FFFFFF" StrokeThickness="1" Padding="10">
                                    <Editor x:Name="TxtVolcDesc" TextColor="White" BackgroundColor="Transparent" HeightRequest="60"/>
                                </Border>
                            </VerticalStackLayout>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <Button Text="SIMPAN GUNUNG BARU" Clicked="OnAddVolcanoClicked"
                                        Style="{StaticResource BtnGhost}" HeightRequest="38"/>
                                <Button x:Name="BtnUpdateVolcano" Grid.Column="1" Text="UPDATE SELECTED"
                                        Clicked="OnUpdateVolcanoClicked" Style="{StaticResource BtnMagenta}"
                                        HeightRequest="38" IsEnabled="False"/>
                            </Grid>

                            <BoxView HeightRequest="1" Color="#26FFFFFF" Margin="0,4"/>

                            <Label Text="DAFTAR GUNUNG BERAPI (TAP UNTUK EDIT / HAPUS)" Style="{StaticResource LblSection}"/>
                            <VerticalStackLayout x:Name="AdminVolcanoList" Spacing="6"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- 2.2. Sensor Management -->
                    <Border Style="{StaticResource GlassCard}">
                        <VerticalStackLayout Spacing="10">
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="📡" FontSize="16"/>
                                <Label Text="ATUR DATA SENSOR &amp; SIMULASI" Style="{StaticResource LblSection}"
                                       TextColor="#4CC9F0" VerticalOptions="Center"/>
                            </HorizontalStackLayout>

                            <VerticalStackLayout Spacing="5">
                                <Label Text="PILIH TARGET GUNUNG" Style="{StaticResource LblSection}"/>
                                <Border StrokeShape="RoundRectangle 10" BackgroundColor="#18FFFFFF"
                                        Stroke="#26FFFFFF" StrokeThickness="1" Padding="4,0">
                                    <Picker x:Name="PickerSimulateVolcano" Title="PILIH GUNUNG..."
                                            TextColor="White" TitleColor="#7B6FAA"
                                            BackgroundColor="Transparent"
                                            SelectedIndexChanged="OnSimulateVolcanoChanged"/>
                                </Border>
                            </VerticalStackLayout>

                            <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                                <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="3">
                                    <Label Text="SO₂ (ppm)" Style="{StaticResource LblSection}"/>
                                    <Border StrokeShape="RoundRectangle 10" BackgroundColor="#18FFFFFF"
                                            Stroke="#26FFFFFF" StrokeThickness="1" Padding="10,8">
                                        <Entry x:Name="TxtSensorSO2" TextColor="White" BackgroundColor="Transparent" Keyboard="Numeric"/>
                                    </Border>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="3">
                                    <Label Text="CO₂ (ppm)" Style="{StaticResource LblSection}"/>
                                    <Border StrokeShape="RoundRectangle 10" BackgroundColor="#18FFFFFF"
                                            Stroke="#26FFFFFF" StrokeThickness="1" Padding="10,8">
                                        <Entry x:Name="TxtSensorCO2" TextColor="White" BackgroundColor="Transparent" Keyboard="Numeric"/>
                                    </Border>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Row="0" Grid.Column="2" Spacing="3">
                                    <Label Text="H₂S (ppm)" Style="{StaticResource LblSection}"/>
                                    <Border StrokeShape="RoundRectangle 10" BackgroundColor="#18FFFFFF"
                                            Stroke="#26FFFFFF" StrokeThickness="1" Padding="10,8">
                                        <Entry x:Name="TxtSensorH2S" TextColor="White" BackgroundColor="Transparent" Keyboard="Numeric"/>
                                    </Border>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="3">
                                    <Label Text="TEMPERATUR (°C)" Style="{StaticResource LblSection}"/>
                                    <Border StrokeShape="RoundRectangle 10" BackgroundColor="#18FFFFFF"
                                            Stroke="#26FFFFFF" StrokeThickness="1" Padding="10,8">
                                        <Entry x:Name="TxtSensorTemp" TextColor="White" BackgroundColor="Transparent" Keyboard="Numeric"/>
                                    </Border>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="3">
                                    <Label Text="SEISMIK (0-10)" Style="{StaticResource LblSection}"/>
                                    <Border StrokeShape="RoundRectangle 10" BackgroundColor="#18FFFFFF"
                                            Stroke="#26FFFFFF" StrokeThickness="1" Padding="10,8">
                                        <Entry x:Name="TxtSensorSeismic" TextColor="White" BackgroundColor="Transparent" Keyboard="Numeric"/>
                                    </Border>
                                </VerticalStackLayout>
                            </Grid>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <Button Text="INPUT MANUAL SENSOR" Clicked="OnManualSensorSaveClicked"
                                        Style="{StaticResource BtnGhost}" HeightRequest="38"/>
                                <Button Grid.Column="1" Text="TRIGGER AUTO-SIM ⚡" Clicked="OnTriggerAutoSimulationClicked"
                                        Style="{StaticResource BtnMagenta}" HeightRequest="38"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- 2.3. User Management -->
                    <Border Style="{StaticResource GlassCard}">
                        <VerticalStackLayout Spacing="10">
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="👥" FontSize="16"/>
                                <Label Text="KELOLA AKUN PENGGUNA" Style="{StaticResource LblSection}"
                                       TextColor="#4CC9F0" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <VerticalStackLayout x:Name="AdminUserListContainer" Spacing="6"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- 2.4. AI Config -->
                    <Border Style="{StaticResource GlassCard}" Margin="0,0,0,32">
                        <VerticalStackLayout Spacing="10">
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="🧠" FontSize="16"/>
                                <Label Text="PARAMETER AI &amp; AMBANG BATAS" Style="{StaticResource LblSection}"
                                       TextColor="#4CC9F0" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <VerticalStackLayout Grid.Column="0" Spacing="4">
                                    <Label Text="LIMIT SO₂ (ppm)" Style="{StaticResource LblSection}"/>
                                    <Border StrokeShape="RoundRectangle 10" BackgroundColor="#18FFFFFF"
                                            Stroke="#26FFFFFF" StrokeThickness="1" Padding="12,8">
                                        <Entry x:Name="TxtThresholdSO2" Text="15.0" TextColor="White"
                                               BackgroundColor="Transparent" Keyboard="Numeric"/>
                                    </Border>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                    <Label Text="LIMIT TEMP (°C)" Style="{StaticResource LblSection}"/>
                                    <Border StrokeShape="RoundRectangle 10" BackgroundColor="#18FFFFFF"
                                            Stroke="#26FFFFFF" StrokeThickness="1" Padding="12,8">
                                        <Entry x:Name="TxtThresholdTemp" Text="320.0" TextColor="White"
                                               BackgroundColor="Transparent" Keyboard="Numeric"/>
                                    </Border>
                                </VerticalStackLayout>
                            </Grid>
                            <Label Text="Parameter ambang batas digunakan oleh sistem Fuzzy Logic dalam menghitung indeks ancaman wilayah sektoral."
                                   TextColor="#7B6FAA" FontSize="10" LineBreakMode="WordWrap"/>
                            <Button Text="TERAPKAN PARAMETER MODEL" Clicked="OnSaveAIConfigClicked"
                                    Style="{StaticResource BtnGhost}" HeightRequest="38"/>
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>