<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VolcanoMonitor.Pages.LoginPage"
             Shell.NavBarIsVisible="False"
             Shell.FlyoutBehavior="Disabled"
             BackgroundColor="#1B0B3B">

    <!-- BG Gradient Layer -->
    <Grid>
        <Border StrokeThickness="0" BackgroundColor="Transparent">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1B0B3B" Offset="0"/>
                    <GradientStop Color="#3A0CA3" Offset="0.6"/>
                    <GradientStop Color="#C61C8B" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Centered Card -->
        <Grid RowDefinitions="*,Auto,*" Padding="24">
            <VerticalStackLayout Grid.Row="1" Spacing="0" MaximumWidthRequest="420"
                                 HorizontalOptions="Center">

                <!-- Logo -->
                <VerticalStackLayout Spacing="6" Margin="0,0,0,32" HorizontalOptions="Center">
                    <Label Text="🌋" FontSize="52" HorizontalOptions="Center"/>
                    <Label Text="VULKANO MONITOR" FontSize="22" FontAttributes="Bold"
                           TextColor="White" HorizontalTextAlignment="Center"/>
                    <Label Text="Sistem Pemantauan Aktivitas Vulkanik" FontSize="12"
                           TextColor="#B9A7D9" HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>

                <!-- Glass Card -->
                <Border Style="{StaticResource GlassCard}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#1AFFFFFF" Offset="0"/>
                            <GradientStop Color="#08FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <VerticalStackLayout Spacing="16">
                        <Label Text="MASUK KE AKUN" FontSize="14" FontAttributes="Bold"
                               TextColor="White" HorizontalTextAlignment="Center"
                               CharacterSpacing="2" Margin="0,0,0,8"/>

                        <!-- Email Field -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="EMAIL / NAMA PENGGUNA" Style="{StaticResource LblSection}"/>
                            <Border StrokeShape="RoundRectangle 12" BackgroundColor="#18FFFFFF"
                                    Stroke="#26FFFFFF" StrokeThickness="1" Padding="14,12">
                                <Entry x:Name="EntryNama" Placeholder="Masukkan email atau nama"
                                       PlaceholderColor="#7B6FAA" TextColor="White"
                                       BackgroundColor="Transparent"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Password Field -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="KATA SANDI" Style="{StaticResource LblSection}"/>
                            <Border StrokeShape="RoundRectangle 12" BackgroundColor="#18FFFFFF"
                                    Stroke="#26FFFFFF" StrokeThickness="1" Padding="14,12">
                                <Entry x:Name="EntryPassword" Placeholder="Masukkan kata sandi"
                                       IsPassword="True" PlaceholderColor="#7B6FAA"
                                       TextColor="White" BackgroundColor="Transparent"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Login Button -->
                        <Button Text="MASUK" Clicked="OnLoginClicked"
                                Style="{StaticResource BtnMagenta}"
                                Margin="0,8,0,0" HeightRequest="48"/>

                        <!-- Register Link -->
                        <Button Text="Belum punya akun? Daftar Sekarang"
                                Clicked="OnGoToRegister"
                                BackgroundColor="Transparent" TextColor="#B9A7D9"
                                FontSize="12" Padding="0"/>

                        <!-- Hint -->
                        <Label Text="Admin: admin@vulkano.com / admin123" FontSize="10"
                               TextColor="#7B6FAA" HorizontalTextAlignment="Center"
                               Margin="0,8,0,0"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>